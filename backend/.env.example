# Backend environment — copy to `.env` and fill in real values (never commit .env).

# Server
PORT=4000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=recycling_platform

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Email (nodemailer) — optional; needed for OTP / notifications
EMAIL_HOST=smtp-relay.example.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=Connect2Recycle <no-reply@example.com>

CLIENT_URL=http://localhost:3000

# Admin bootstrap (bcrypt hash of the admin password)
ADMIN_PASS=your_bcrypt_hash

# Rewards ledger (Hyperledger Fabric REST bridge) — optional; feature is off by
# default. The URL is an ephemeral tunnel; the key stays server-side only.
REWARDS_LEDGER_URL=https://your-ledger-tunnel.example.com
REWARDS_LEDGER_API_KEY=your_ledger_api_key
REWARDS_POINTS_PER_KG=10
